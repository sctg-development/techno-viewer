# Application URLs
STORE_URL=http://localhost:5173
CORS_ORIGIN=http://localhost:5173

# PostHog analytics (optional)
POSTHOG_HOST=https://eu.i.posthog.com
POSTHOG_PROJECT_TOKEN=your_posthog_token_here

# Cloudflare account (for deployment)
COUDFLARE_ACCOUNT_IDD=your_cloudflare_account_id_here

# AI proxy (optional, enables AI features in Monaco viewer)
# See https://github.com/sctg-development/ai-proxy-cloudflare
AI_PROXY_URL=https://your-ai-proxy.example.com/groq/v1/chat/completions
